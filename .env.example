APP_ENV=development
API_BASE_URL=http://localhost:8000
SECRET_KEY=replace-with-random-string
ADMIN_API_KEY=

# Comma-separated origins in production (no wildcard)
CORS_ALLOWED_ORIGINS=*

# SQLite paths (default: ./data/jobs.db and ./downloads)
DATA_DIR=./data
DOWNLOAD_DIR=./downloads
DATABASE_URL=

# Trust X-Forwarded-For (only behind a trusted reverse proxy)
TRUST_PROXY=0

# Limits
MAX_CONCURRENT_JOBS_GLOBAL=3
MAX_CONCURRENT_JOBS_PER_IP=2
MAX_DURATION_SECONDS=14400
MAX_FILE_BYTES=3221225472
MIN_FREE_DISK_BYTES=536870912
FILE_EXPIRY_MINUTES=60
QUEUED_JOB_TTL_MINUTES=30

RATE_LIMIT_INFO=30/minute
RATE_LIMIT_JOBS=8/hour

# Launch scope: allowed URL hosts (comma-separated, lowercase)
SUPPORTED_URL_HOSTS=youtube.com,www.youtube.com,youtu.be,m.youtube.com,music.youtube.com

LOG_LEVEL=INFO
